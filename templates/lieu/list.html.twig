{% extends 'layout/base.html.twig' %}

{% block title %}Gestion des Lieux{% endblock %}

{% block main %}
    <h1>Liste des lieux</h1>
    <a class="btn" href="{{ path('lieu_create') }}">Proposer un lieu</a>
    <hr>
    {% if lieux is empty %}
        <br>
        <p>Il n'y actuellement aucuns lieux disponibles.</p>
    {% else %}

        <section>
            <table>
                <thead>
                <tr>
                    <th>Nom</th>
                    <th>Ville</th>
                    <th>Action</th>
                </tr>
                </thead>
                <tbody>
                {% for lieu in lieux %}
                    <tr>
                        <td><p>{{ lieu.nom }}</p></td>
                        <td><p>{{ lieu.ville.nom }}</p></td>
                        <td><a class="btn" href="{{ path('lieu_detail', {'id': lieu.id}) }}">Détail</a></td>
                    </tr>
                {% endfor %}

                </tbody>
            </table>
        </section>
    {% endif %}
{% endblock %}
