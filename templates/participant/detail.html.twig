{% extends 'layout/base.html.twig' %}

{% block title %}Mon profil{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/openModal.js') }}" defer></script>
{% endblock %}

{% block main %}
    <div class="w-full space-y-8">

        <div class="flex  gap-5">
            {% if user.image %}
                <img
                    src="{{ asset('uploads/' ~ user.image) }}"
                    alt="{{ user.pseudo }}"
                    class="img-profil"
                >
            {% else %}
                <img
                    src="https://ui-avatars.com/api/?name={{ user.pseudo }}&background=5C7D5C&color=fff"
                    alt="{{ user.pseudo }}"
                    class="img-profil"
                >
            {% endif %}
            <div class=" ">
                <h1 class="!text-left">
                    {% if app.user == user %}
                        {{ user.prenom }} {{ user.nom }}
                    {% else %}
                        @{{ user.pseudo }}
                    {% endif %}
                </h1>
                {% if app.user == user %}
                    <div class="flex items-center gap-2">
                        <h5>
                            @{{ user.pseudo }}
                        </h5>
                        {% if user.administrateur %}
                            <h5
                                class="px-3 py-1 rounded-full bg-red-200 text-red-600">
                                Administrateur
                            </h5>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>
        {% if app.user == user %}
            <div class="flex gap-2">
                <a href="{{ path('participant_profil_modify') }}" class="btn">
                    modifier le profil
                </a>
                <a href="{{ path('participant_password_modify') }}" class="btn">
                    modifier le mot de passe
                </a>
            </div>
        {% endif %}
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <article>
                <div class="text-4xl font-black text-[#5C7D5C]">
                    {{ eventsCreated }}
                </div>
                <p class="mt-2 text-sm text-gray-600">
                    Événements créés
                </p>
            </article>
            <article>
                <div class="text-4xl font-black text-[#5C7D5C]">
                    {{ participations }}
                </div>
                <p class="mt-2 text-sm text-gray-600">
                    Participations
                </p>
            </article>
            <article>
                <div class="text-4xl font-black text-[#5C7D5C]">
                    {{ upcomingEvents }}
                </div>
                <p class="mt-2 text-sm text-gray-600">
                    Évènements à venir
                </p>
            </article>
        </div>
        {% if app.user == user %}
            <section>
                <article>
                    <h2>
                        Informations
                    </h2>
                    <div class="flex flex-col gap-2">
                        <div class="text-left flex flex-col">
                            <label>
                                Email
                            </label>
                            <p>
                                {{ user.email }}
                            </p>
                        </div>
                        <div class="text-left flex flex-col ">
                            <label>
                                Téléphone
                            </label>
                            <p class="!text-sm">
                                {{ user.telephone ?? 'Non renseigné' }}
                            </p>
                        </div>
                        <div class="text-left flex flex-col">
                            <label>
                                Site
                            </label>
                            <p class="!text-sm">
                                {{ user.site.nom ?? 'Non défini' }}
                            </p>
                        </div>
                    </div>
                </article>
                <article>
                    <h2>Activité récente</h2>
                    <div class="">
                        {% for event in recentEvents %}

                            <div
                                onclick="openModal('modal-{{ event.id }}')"
                                class="group flex items-center justify-between py-2 px-3 rounded-lg cursor-pointer hover:bg-[#F4F6F1] transition"
                            >

                                <div class=" text-left">
                                    <h6 class="text-xs font-bold uppercase text-[var(--color-primary)] truncate">
                                        {{ event.nom|length > 26 ? event.nom|slice(0, 24) ~ '…' : event.nom }}
                                    </h6>
                                    <label class="">
                                        {{ event.dateHeureDebut|date('d/m/Y') }}
                                    </label>
                                </div>

                                <span class="opacity-0 group-hover:opacity-100 transition text-gray-400">
                            →
                        </span>

                            </div>

                            {% include 'layout/fragments/modals/profil-event-modal.html.twig' with {
                                event: event
                            } %}
                        {% endfor %}
                    </div>
                </article>
            </section>
        {% endif %}
        <section>
            <article>
                <h2>
                    {% if app.user == user %}Mes{% else %}Ses{% endif %} événements
                </h2>
                <div class=" h-50 ">
                    {% for event in userEvents %}

                        <div
                            onclick="openModal('modal-{{ event.id }}')"
                            class="group flex items-center justify-between py-2 px-3 rounded-lg cursor-pointer hover:bg-[#F4F6F1] transition"
                        >

                            <div class=" text-left">
                                <h6 class="text-xs font-bold uppercase text-[var(--color-primary)] truncate">
                                    {{ event.nom|length > 26 ? event.nom|slice(0, 24) ~ '…' : event.nom }}
                                </h6>
                                <label class="">
                                    {{ event.dateHeureDebut|date('d/m/Y') }}
                                </label>
                            </div>

                            <span class="opacity-0 group-hover:opacity-100 transition text-gray-400">
                            →
                        </span>

                        </div>

                        {% include 'layout/fragments/modals/profil-event-modal.html.twig' with {
                            event: event
                        } %}
                    {% endfor %}
                </div>
            </article>
            <article>
                <h2>
                    Événements à venir
                </h2>
                {% for event in user.sorties %}

                    <div
                        onclick="openModal('modal-{{ event.id }}')"
                        class="group flex items-center justify-between py-2 px-3 rounded-lg cursor-pointer hover:bg-[#F4F6F1] transition"
                    >

                        <div class=" text-left">
                            <h6 class="text-xs font-bold uppercase text-[var(--color-primary)] truncate">
                                {{ event.nom|length > 26 ? event.nom|slice(0, 24) ~ '…' : event.nom }}
                            </h6>
                            <label class="">
                                {{ event.dateHeureDebut|date('d/m/Y') }}
                            </label>
                        </div>

                        <span class="opacity-0 group-hover:opacity-100 transition text-gray-400">
                            →
                        </span>

                    </div>

                    {% include 'layout/fragments/modals/profil-event-modal.html.twig' with {
                        event: event
                    } %}

                {% endfor %}
            </article>
        </section>
    </div>
    {% if app.user == user %}
        <a href="{{ path('participant_delete_account') }}"
           class="mt-4 text-red-600 hover:text-red-800 hover:underline"
           onclick="openDeleteModal(event)">
            Supprimer mon compte
        </a>
        {% include 'layout/fragments/modals/profil-delete-account.html.twig' %}
    {% endif %}
{% endblock %}
