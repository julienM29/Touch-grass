{% extends 'layout/base.html.twig' %}

{% block title %}Mon profil{% endblock %}

{% block main %}

    <div class="w-full space-y-8">

        <div class="flex  gap-5">
                 {% if user.image %}
                    <img
                        src="{{ asset('uploads/' ~ user.image) }}"
                        alt="{{ user.pseudo }}"
                        class="img-profil"
                    >
                {% else %}
                    <img
                        src="https://ui-avatars.com/api/?name={{ user.pseudo }}&background=5C7D5C&color=fff"
                        alt="{{ user.pseudo }}"
                        class="img-profil"
                    >
                {% endif %}
             <div class=" ">
                <h1 class="!text-left">
                    {{ user.prenom }} {{ user.nom }}
                </h1>
                <div class="flex items-center gap-2">
                    <h5>
                        @{{ user.pseudo }}
                    </h5>
                    {% if user.administrateur %}
                        <h5
                            class="px-3 py-1 rounded-full bg-red-200 text-red-600">
                                Administrateur
                            </h5>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="flex gap-2">
            <a href="{{ path('participant_profil_modify') }}" class="btn">
                modifier le profil
            </a>
            <a href="{{ path('participant_profil_modify') }}" class="btn">
                modifier le mot de passe
            </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <article>
                <div class="text-4xl font-black text-[#5C7D5C]">
                    {{ eventsCreated }}
                </div>
                <p class="mt-2 text-sm text-gray-600">
                    Événements créés
                </p>
            </article>
            <article>
                <div class="text-4xl font-black text-[#5C7D5C]">
                    {{ participations }}
                </div>
                <p class="mt-2 text-sm text-gray-600">
                    Participations
                </p>
            </article>
            <article>
                <div class="text-4xl font-black text-[#5C7D5C]">
                    {{ upcomingEvents }}
                </div>
                <p class="mt-2 text-sm text-gray-600">
                    Évènements à venir
                </p>
            </article>
        </div>
        <section >
            <article>
                <h2>
                    Informations
                </h2>
                <div class="flex flex-col gap-2">
                    <div class="text-left flex flex-col">
                        <label>
                            Email
                        </label>
                        <p>
                            {{ user.email }}
                        </p>
                    </div>
                    <div class="text-left flex flex-col ">
                        <label>
                            Téléphone
                        </label>
                        <p class="!text-sm">
                            {{ user.telephone ?? 'Non renseigné' }}
                        </p>
                    </div>
                    <div class="text-left flex flex-col">
                        <label>
                            Site
                        </label>
                        <p class="!text-sm">
                            {{ user.site.nom ?? 'Non défini' }}
                        </p>
                    </div>
                </div>
            </article>
            <article>
                <h2>Activité récente</h2>
                <div class="">
                </div>
            </article>
            <article class="bg-white rounded-2xl p-4 border border-green-100 shadow-sm">
                <h2>
                    Mes événements
                </h2>
                <div class=" h-50 ">
                </div>
            </article>
            <article class="bg-white rounded-2xl p-4 border border-green-100 shadow-sm">
                <h2>
                    Événements à venir
                </h2>
                <div class="">
                </div>
            </article>
        </section>
    </div>
{% endblock %}
