{% extends 'layout/base.html.twig' %}

{% block title %}Mon profil{% endblock %}

{% block main %}

    <div class="min-h-screen bg-gradient-to-br from-green-50 to-white py-8 px-4">

        <div class="max-w-6xl mx-auto">

            <!-- CARD PROFIL -->
            <div class="bg-white/90 backdrop-blur border border-green-100 rounded-3xl shadow-xl overflow-hidden">

                <!-- BANNER -->
                <div class="h-24 bg-gradient-to-r from-green-500 to-green-600"></div>

                <div class="px-6 sm:px-10 pb-10">

                    <!-- HEADER -->
                    <div class="-mt-16 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6">

                        <div class="flex flex-col sm:flex-row items-center sm:items-end gap-4">

                            <!-- AVATAR -->
                            <div class="w-32 h-32 rounded-full border-4 border-white shadow-lg overflow-hidden bg-green-100">

                                {% if user.image %}
                                    <img src="{{ asset('uploads/' ~ user.image) }}"
                                         class="w-full h-full object-cover"
                                         alt="{{ user.pseudo }}">
                                {% else %}
                                    <img src="https://ui-avatars.com/api/?name={{ user.pseudo }}"
                                         class="w-full h-full object-cover"
                                         alt="{{ user.pseudo }}">
                                {% endif %}

                            </div>

                            <!-- INFOS USER -->
                            <div class="text-center sm:text-left">

                                <h1 class="text-3xl font-bold text-gray-800">
                                    {{ user.prenom }} {{ user.nom }}
                                </h1>

                                <p class="text-green-600 font-medium">
                                    @{{ user.pseudo }}
                                </p>

                                {% if user.administrateur %}
                                    <span class="inline-block mt-2 px-3 py-1 rounded-full bg-red-100 text-red-600 text-xs font-semibold">
                                    Administrateur
                                </span>
                                {% endif %}

                            </div>
                        </div>

                        <a href="#"
                           class="bg-green-600 hover:bg-green-700 text-white px-5 py-3 rounded-xl shadow-md transition">
                            Modifier le profil
                        </a>

                    </div>

                    <!-- STATS -->
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mt-10">

                        <div class="bg-gradient-to-br from-green-50 to-white border border-green-400 rounded-2xl p-6 text-center hover:scale-105 transition">
                            <div class="text-3xl font-bold text-green-600">
                                {{ eventsCreated }}
                            </div>
                            <div class="text-sm text-gray-600 mt-1">
                                🎉 Événements créés
                            </div>
                        </div>

                        <div class="bg-gradient-to-br from-green-50 to-white border border-green-400 rounded-2xl p-6 text-center hover:scale-105 transition">
                            <div class="text-3xl font-bold text-green-600">
                                {{ participations }}
                            </div>
                            <div class="text-sm text-gray-600 mt-1">
                                👥 Participations
                            </div>
                        </div>

                        <div class="bg-gradient-to-br from-green-50 to-white border border-green-400 rounded-2xl p-6 text-center hover:scale-105 transition">
                            <div class="text-3xl font-bold text-green-600">
                                {{ upcomingEvents }}
                            </div>
                            <div class="text-sm text-gray-600 mt-1">
                                📅 À venir
                            </div>
                        </div>

                    </div>

                    <!-- INFOS -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-10">

                        <div class="bg-green-50 border border-green-100 rounded-2xl p-6">

                            <h2 class="text-lg font-bold text-green-700 mb-4">
                                Informations
                            </h2>

                            <div class="space-y-3 text-sm">

                                <p><span class="text-gray-500">Email :</span> {{ user.email }}</p>

                                <p><span class="text-gray-500">Téléphone :</span> {{ user.telephone ?? 'Non renseigné' }}</p>

                                <p><span class="text-gray-500">Site :</span> {{ user.site.nom ?? 'Non défini' }}</p>

                            </div>

                        </div>

                        <div class="bg-white border border-green-100 rounded-2xl p-6">

                            <h2 class="text-lg font-bold text-green-700 mb-4">
                                Activité récente
                            </h2>

                            <p class="text-gray-500 text-sm">
                                Statistiques basées sur ton activité sur la plateforme.
                            </p>

                        </div>

                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-10">
                        <!-- MES EVENEMENTS -->
                        <div class="bg-white border border-green-100 rounded-2xl p-6">

                            <h2 class="text-xl font-bold text-green-700 mb-5">
                                Mes événements
                            </h2>

                            {% if userEvents|length > 0 %}

                                <div class="space-y-4">

                                    {% for event in userEvents %}

                                        <div class="border border-green-100 rounded-xl p-4 hover:shadow-sm transition">

                                            <h3 class="font-bold text-gray-800">
                                                {{ event.nom }}
                                            </h3>

                                            <p class="text-sm text-gray-500">
                                                {{ event.siteOrganisateur.nom ?? 'N/A' }}
                                            </p>

                                            <p class="text-xs text-gray-400 mt-1">
                                                {{ event.date|date('d/m/Y H:i') }}
                                            </p>

                                        </div>

                                    {% endfor %}

                                </div>

                            {% else %}

                                <p class="text-gray-500 text-sm">
                                    Aucun événement créé.
                                </p>

                            {% endif %}

                        </div>
                        <div class="bg-white border border-green-100 rounded-2xl p-6">

                            <h2 class="text-xl font-bold text-green-700 mb-5">
                                Événements à venir
                            </h2>

                            {% if upcomingEventsList is defined and upcomingEventsList|length > 0 %}

                                <div class="space-y-4">

                                    {% for event in upcomingEventsList %}

                                        <div class="border border-green-100 rounded-xl p-4 hover:shadow-sm transition">

                                            <h3 class="font-bold text-gray-800">
                                                {{ event.nom }}
                                            </h3>

                                            <p class="text-sm text-gray-500">
                                                {{ event.siteOrganisateur.nom ?? 'N/A' }}
                                            </p>

                                            <p class="text-xs text-gray-400 mt-1">
                                                {{ event.date|date('d/m/Y H:i') }}
                                            </p>

                                            <span class="inline-block mt-2 text-green-600 text-xs font-semibold">
                        À venir
                    </span>

                                        </div>

                                    {% endfor %}

                                </div>

                            {% else %}

                                <p class="text-gray-500 text-sm">
                                    Aucun événement à venir.
                                </p>

                            {% endif %}

                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

{% endblock %}
