{% extends 'layout/base.html.twig' %}

{% block title %}Mon profil{% endblock %}

{% block main %}

    <div class="w-full space-y-8">
            <div>
                <div class="flex justify-end">

                </div>
                <div class="flex items-center gap-5">

                    <div
                        class="w-28 h-28 shrink-0 rounded-full border-4 border-[#EEF3EE] overflow-hidden shadow-xl bg-white">
                        {% if user.image %}
                            <img
                                src="{{ asset('uploads/' ~ user.image) }}"
                                alt="{{ user.pseudo }}"
                                class="w-full h-full object-cover"
                            >
                        {% else %}
                            <img
                                src="https://ui-avatars.com/api/?name={{ user.pseudo }}&background=5C7D5C&color=fff"
                                alt="{{ user.pseudo }}"
                                class="w-full h-full object-cover"
                            >
                        {% endif %}
                    </div>
                    <div class="flex flex-col text-left">
                        <h1 class="">
                            {{ user.prenom }} {{ user.nom }}
                        </h1>

                        <div class="flex gap-2">
                        <h5>
                            @{{ user.pseudo }}
                        </h5>

                        {% if user.administrateur %}
                            <span
                                class="inline-flex w-fit px-3 py-1 rounded-full bg-red-100 text-red-600 text-xs font-semibold">
                                Administrateur
                            </span>
                        {% endif %}
                        </div>
                    </div>
                </div>

            </div>
        <section class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <article>
                <div class="text-4xl font-black text-[#5C7D5C]">
                    {{ eventsCreated }}
                </div>
                <p class="mt-2 text-sm text-gray-600">
                    Événements créés
                </p>
            </article>
            <article>
                <div class="text-4xl font-black text-[#5C7D5C]">
                    {{ participations }}
                </div>
                <p class="mt-2 text-sm text-gray-600">
                    Participations
                </p>
            </article>
            <article>
                <div class="text-4xl font-black text-[#5C7D5C]">
                    {{ upcomingEvents }}
                </div>
                <p class="mt-2 text-sm text-gray-600">
                    Évènements à venir
                </p>
            </article>
        </section>
        <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <article>
                <h2>
                    Informations
                </h2>
                <div class="flex flex-col gap-2">
                    <div class="text-left flex flex-col">
                        <label>
                            Email
                        </label>
                        <p>
                            {{ user.email }}
                        </p>
                    </div>
                    <div class="text-left flex flex-col ">
                        <label>
                            Téléphone
                        </label>
                        <p class="!text-sm">
                            {{ user.telephone ?? 'Non renseigné' }}
                        </p>
                    </div>
                    <div class="text-left flex flex-col">
                        <label>
                            Site
                        </label>
                        <p class="!text-sm">
                            {{ user.site.nom ?? 'Non défini' }}
                        </p>
                    </div>
                </div>
            </article>
            <article>
                <h2>Activité récente</h2>
                <div class="">
                </div>
            </article>
        </section>
        <section class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
            <article class="bg-white rounded-2xl p-4 border border-green-100 shadow-sm">
                <h2>
                    Mes événements
                </h2>
                <div class=" h-50 ">
                </div>
            </article>
            <article class="bg-white rounded-2xl p-4 border border-green-100 shadow-sm">
                <h2>
                    Événements à venir
                </h2>
                <div class="">
                </div>
            </article>
        </section>
    </div>
{% endblock %}
