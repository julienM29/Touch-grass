{% extends 'layout/base.html.twig' %}

{% block title %}Mon profil{% endblock %}

{% block main %}
    <div class="min-h-screen bg-gradient-to-br from-green-50 to-white py-8 px-3 sm:px-6">

        <div class="max-w-5xl mx-auto">

            <!-- Header -->
            <div class="bg-white/90 backdrop-blur border border-green-100 rounded-3xl shadow-xl overflow-hidden">

                <!-- Banner -->
                <div class="h-32 bg-gradient-to-r from-green-500 to-green-600"></div>

                <!-- Content -->
                <div class="px-5 sm:px-8 pb-8">

                    <!-- Avatar -->
                    <div class="-mt-16 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">

                        <div class="flex flex-col sm:flex-row items-center sm:items-end gap-4">

                            <div class="w-32 h-32 rounded-full border-4 border-white shadow-lg overflow-hidden bg-green-100">

                                {% if user.image %}
                                    <img
                                        src="{{ asset('uploads/' ~ user.image) }}"
                                        alt="{{ user.pseudo }}"
                                        class="w-full h-full object-cover"
                                    >
                                {% else %}
                                    <img
                                        src="https://ui-avatars.com/api/?name={{ user.pseudo }}"
                                        alt="{{ user.pseudo }}"
                                        class="w-full h-full object-cover"
                                    >
                                {% endif %}

                            </div>

                            <div class="text-center sm:text-left">

                                <h1 class="text-3xl font-bold text-gray-800">
                                    {{ user.prenom }} {{ user.nom }}
                                </h1>

                                <p class="text-green-600 font-medium text-lg">
                                    @{{ user.pseudo }}
                                </p>

                                <div class="mt-2 flex flex-wrap gap-2 justify-center sm:justify-start">

                                    {% if user.administrateur %}
                                        <span class="px-3 py-1 rounded-full bg-red-100 text-red-600 text-xs font-semibold">
                                        Administrateur
                                    </span>
                                    {% endif %}

                                    {% if user.actif %}
                                        <span class="px-3 py-1 rounded-full bg-green-100 text-green-600 text-xs font-semibold">
                                        Actif
                                    </span>
                                    {% else %}
                                        <span class="px-3 py-1 rounded-full bg-gray-100 text-gray-500 text-xs font-semibold">
                                        Inactif
                                    </span>
                                    {% endif %}

                                </div>

                            </div>

                        </div>

                        <!-- Edit button -->
                        <a href="#"
                           class="bg-green-600 hover:bg-green-700 text-white px-5 py-3 rounded-xl shadow-md transition font-medium text-center">
                            Modifier le profil
                        </a>

                    </div>

                    <!-- Infos -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mt-10">

                        <!-- Contact -->
                        <div class="bg-green-50 border border-green-100 rounded-2xl p-5">

                            <h2 class="text-lg font-bold text-green-700 mb-4">
                                Informations
                            </h2>

                            <div class="space-y-4">

                                <div>
                                    <p class="text-sm text-gray-500">
                                        Email
                                    </p>

                                    <p class="font-medium text-gray-800 break-all">
                                        {{ user.email }}
                                    </p>
                                </div>

                                <div>
                                    <p class="text-sm text-gray-500">
                                        Téléphone
                                    </p>

                                    <p class="font-medium text-gray-800">
                                        {{ user.telephone }}
                                    </p>
                                </div>

                                <div>
                                    <p class="text-sm text-gray-500">
                                        Site
                                    </p>

                                    <p class="font-medium text-gray-800">
                                        {{ user.site.nom }}
                                    </p>
                                </div>

                            </div>

                        </div>

                        <!-- Stats -->
                        <div class="bg-white border border-green-100 rounded-2xl p-5 shadow-sm">

                            <h2 class="text-lg font-bold text-green-700 mb-4">
                                Activité
                            </h2>

                            <div class="grid grid-cols-2 gap-4">

                                <div class="bg-green-50 rounded-2xl p-5 text-center">

                                    <p class="text-3xl font-bold text-green-600">
                                        {{ user.sorties|length }}
                                    </p>

                                    <p class="text-sm text-gray-600 mt-1">
                                        Sorties
                                    </p>

                                </div>

                                <div class="bg-green-50 rounded-2xl p-5 text-center">

                                    <p class="text-3xl font-bold text-green-600">
                                        {{ user.roles|length }}
                                    </p>

                                    <p class="text-sm text-gray-600 mt-1">
                                        Rôles
                                    </p>

                                </div>

                            </div>

                        </div>

                    </div>

                    <!-- Sorties -->
                    <div class="mt-10">

                        <h2 class="text-2xl font-bold text-green-700 mb-5">
                            Mes sorties
                        </h2>

                        {% if user.sorties|length > 0 %}

                            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">

                                {% for sortie in user.sorties %}

                                    <div class="bg-white border border-green-100 rounded-2xl p-5 shadow-sm hover:shadow-md transition">

                                        <h3 class="font-bold text-lg text-gray-800 mb-2">
                                            {{ sortie.nom }}
                                        </h3>

                                        <p class="text-sm text-gray-500">
                                            Organisée sur :
                                            {{ sortie.siteOrganisateur.nom ?? 'N/A' }}
                                        </p>

                                    </div>

                                {% endfor %}

                            </div>

                        {% else %}

                            <div class="bg-white border border-dashed border-green-200 rounded-2xl p-10 text-center">

                                <p class="text-gray-500">
                                    Aucune sortie pour le moment.
                                </p>

                            </div>

                        {% endif %}

                    </div>

                </div>

            </div>

        </div>
    </div>
{% endblock %}
