{% extends 'layout/base.html.twig' %}

{% block title %}Log in{% endblock %}

{% block main %}

    <h1>
        Connectez-vous
    </h1>

    {% if error %}
        <div class="mb-4 text-sm text-red-600 bg-red-50 border border-red-200 rounded-xl px-4 py-3">
            Email ou mot de passe incorrect
        </div>
    {% endif %}

    {% if app.user %}
        <div class="mb-4 text-sm text-gray-700 bg-gray-50 border border-gray-200 rounded-xl px-4 py-3">
            You are logged in as {{ app.user.userIdentifier }},
            <a href="{{ logout_path() }}" class="text-green-600 hover:underline">Logout</a>
        </div>
    {% endif %}

    <form method="post">

        <!-- Email -->
        <div>
            <label for="username">
                Email
            </label>

            <input
                type="email"
                value="{{ last_username }}"
                name="_username"
                id="username"
                required
                autofocus
                autocomplete="email"
            >
        </div>

        <!-- Password -->
        <div>
            <label for="password">
                Mot de passe
            </label>

            <input
                type="password"
                name="_password"
                id="password"
                required
                autocomplete="current-password"
            >
        </div>

        <!-- CSRF -->
        <input type="hidden"
               name="_csrf_token"
               value="{{ csrf_token('authenticate') }}">
        <div class="flex items-start ml-2">
            <label>
                <input type="checkbox" name="_remember_me">
                Se souvenir de moi
            </label>
        </div>
        <!-- Submit -->
        <button type="submit">
            Connexion
        </button>

    </form>

{% endblock %}
