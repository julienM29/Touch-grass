{% extends 'layout/base.html.twig' %}

{% block title %}Log in{% endblock %}

{% block main %}
    <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-green-50 to-white p-3 sm:p-4">

        <div class="w-full max-w-md bg-white/90 backdrop-blur rounded-2xl shadow-xl border border-green-100 p-5 sm:p-8">

            <h1 class="text-2xl sm:text-3xl font-bold text-center text-green-700 mb-5 sm:mb-6">
                Connectez-vous
            </h1>

            {% if error %}
                <div class="mb-4 text-sm text-red-600 bg-red-50 border border-red-200 rounded-xl px-4 py-3">
                    Email ou mot de passe incorrect
                </div>
            {% endif %}

            {% if app.user %}
                <div class="mb-4 text-sm text-gray-700 bg-gray-50 border border-gray-200 rounded-xl px-4 py-3">
                    You are logged in as {{ app.user.userIdentifier }},
                    <a href="{{ logout_path() }}" class="text-green-600 hover:underline">Logout</a>
                </div>
            {% endif %}

            <form method="post" class="space-y-4 sm:space-y-5">

                <!-- Email -->
                <div>
                    <label for="username" class="block text-sm font-medium text-gray-700 mb-1">
                        Email
                    </label>

                    <input
                        type="email"
                        value="{{ last_username }}"
                        name="_username"
                        id="username"
                        required
                        autofocus
                        autocomplete="email"
                        class="w-full px-3 sm:px-4 py-2.5 sm:py-3 border border-green-300 rounded-xl
                           focus:outline-none focus:ring-4 focus:ring-green-200 focus:border-green-500 transition"
                    >
                </div>

                <!-- Password -->
                <div>
                    <label for="password" class="block text-sm font-medium text-gray-700 mb-1">
                        Mot de passe
                    </label>

                    <input
                        type="password"
                        name="_password"
                        id="password"
                        required
                        autocomplete="current-password"
                        class="w-full px-3 sm:px-4 py-2.5 sm:py-3 border border-green-300 rounded-xl
                           focus:outline-none focus:ring-4 focus:ring-green-200 focus:border-green-500 transition"
                    >
                </div>

                <!-- CSRF -->
                <input type="hidden"
                       name="_csrf_token"
                       value="{{ csrf_token('authenticate') }}">

                <!-- Submit -->
                <button type="submit"
                        class="w-full bg-green-600 hover:bg-green-700 active:scale-[0.99]
                           text-white font-semibold py-3 rounded-xl transition shadow-md">
                    Connexion
                </button>

            </form>

        </div>
    </div>
{% endblock %}
