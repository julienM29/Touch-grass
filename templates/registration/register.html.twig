{% extends 'layout/base.html.twig' %}

{% block title %}Register{% endblock %}

{% block main %}
    <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-green-50 to-white p-3 sm:p-4">

        <div class="w-full max-w-lg bg-white/90 backdrop-blur rounded-2xl shadow-xl border border-green-100 p-5 sm:p-8">

            <h1 class="text-2xl sm:text-3xl font-bold text-center text-green-700 mb-5 sm:mb-6">
                Create your account
            </h1>

            {{ form_errors(registrationForm) }}

            {{ form_start(registrationForm, {'attr': {'class': 'space-y-4 sm:space-y-5'}}) }}

            <!-- Avatar -->
            <div class="flex flex-col items-center mb-4 sm:mb-6">

                <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-full bg-green-100 border-2 border-green-300 overflow-hidden flex items-center justify-center">
                    <img id="preview"
                         src="https://ui-avatars.com/api/?name={{ registrationForm.vars.data.pseudo ?? 'User' }}"
                         class="w-full h-full object-cover">
                </div>

                <label class="mt-3 cursor-pointer text-sm text-green-700 font-medium hover:underline text-center">
                    Choisir une photo
                    {{ form_widget(registrationForm.image, {
                        'attr': {
                            'class': 'hidden',
                            'onchange': 'previewImage(event)'
                        }
                    }) }}
                </label>

                {{ form_errors(registrationForm.image) }}

            </div>

            <!-- Prénom + Nom -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">

                <div>
                    {{ form_label(registrationForm.prenom, null, {
                        'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}
                    }) }}

                    {{ form_widget(registrationForm.prenom, {
                        'attr': {
                            'class': 'w-full px-3 sm:px-4 py-2.5 sm:py-3 border border-green-300 rounded-xl focus:outline-none focus:ring-4 focus:ring-green-200 focus:border-green-500 transition'
                        }
                    }) }}

                    {{ form_errors(registrationForm.prenom) }}
                </div>

                <div>
                    {{ form_label(registrationForm.nom, null, {
                        'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}
                    }) }}

                    {{ form_widget(registrationForm.nom, {
                        'attr': {
                            'class': 'w-full px-3 sm:px-4 py-2.5 sm:py-3 border border-green-300 rounded-xl focus:outline-none focus:ring-4 focus:ring-green-200 focus:border-green-500 transition'
                        }
                    }) }}

                    {{ form_errors(registrationForm.nom) }}
                </div>

            </div>

            <!-- Pseudo -->
            <div>
                {{ form_label(registrationForm.pseudo, null, {
                    'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}
                }) }}

                {{ form_widget(registrationForm.pseudo, {
                    'attr': {
                        'class': 'w-full px-3 sm:px-4 py-2.5 sm:py-3 border border-green-300 rounded-xl focus:outline-none focus:ring-4 focus:ring-green-200 focus:border-green-500 transition'
                    }
                }) }}

                {{ form_errors(registrationForm.pseudo) }}
            </div>

            <!-- Email -->
            <div>
                {{ form_label(registrationForm.email, null, {
                    'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}
                }) }}

                {{ form_widget(registrationForm.email, {
                    'attr': {
                        'class': 'w-full px-3 sm:px-4 py-2.5 sm:py-3 border border-green-300 rounded-xl focus:outline-none focus:ring-4 focus:ring-green-200 focus:border-green-500 transition'
                    }
                }) }}

                {{ form_errors(registrationForm.email) }}
            </div>

            <!-- Téléphone -->
            <div>
                {{ form_label(registrationForm.telephone, null, {
                    'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}
                }) }}

                {{ form_widget(registrationForm.telephone, {
                    'attr': {
                        'class': 'w-full px-3 sm:px-4 py-2.5 sm:py-3 border border-green-300 rounded-xl focus:outline-none focus:ring-4 focus:ring-green-200 focus:border-green-500 transition'
                    }
                }) }}

                {{ form_errors(registrationForm.telephone) }}
            </div>

            <!-- Site -->
            <div>
                {{ form_label(registrationForm.site, null, {
                    'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}
                }) }}

                {{ form_widget(registrationForm.site, {
                    'attr': {
                        'class': 'w-full px-3 sm:px-4 py-2.5 sm:py-3 border border-green-300 rounded-xl focus:outline-none focus:ring-4 focus:ring-green-200 focus:border-green-500 transition'
                    }
                }) }}

                {{ form_errors(registrationForm.site) }}
            </div>

            <!-- Password -->
            <div>
                {{ form_label(registrationForm.plainPassword.first, 'Mot de passe', {
                    'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}
                }) }}

                {{ form_widget(registrationForm.plainPassword.first, {
                    'attr': {
                        'class': 'w-full px-3 sm:px-4 py-2.5 sm:py-3 border border-green-300 rounded-xl focus:outline-none focus:ring-4 focus:ring-green-200 focus:border-green-500 transition'
                    }
                }) }}

                {{ form_errors(registrationForm.plainPassword.first) }}
            </div>

            <!-- Confirm -->
            <div>
                {{ form_label(registrationForm.plainPassword.second, 'Confirmer le mot de passe', {
                    'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}
                }) }}

                {{ form_widget(registrationForm.plainPassword.second, {
                    'attr': {
                        'class': 'w-full px-3 sm:px-4 py-2.5 sm:py-3 border border-green-300 rounded-xl focus:outline-none focus:ring-4 focus:ring-green-200 focus:border-green-500 transition'
                    }
                }) }}

                {{ form_errors(registrationForm.plainPassword.second) }}
            </div>

            <!-- Terms -->
            <div class="flex items-center gap-2 text-gray-700">
                {{ form_widget(registrationForm.agreeTerms, {
                    'attr': {
                        'class': 'h-4 w-4 text-green-600 focus:ring-green-500 border-green-200 rounded'
                    }
                }) }}

                {{ form_label(registrationForm.agreeTerms, 'Accepter les conditions', {
                    'label_attr': {'class': 'text-sm text-gray-500'}
                }) }}
            </div>

            {{ form_errors(registrationForm.agreeTerms) }}

            <!-- Submit -->
            <button type="submit"
                    class="w-full bg-green-600 hover:bg-green-700 active:scale-[0.99] text-white font-semibold py-3 rounded-xl transition shadow-md">
                Créer le compte
            </button>

            {{ form_end(registrationForm) }}

        </div>
    </div>

    <script>
        function previewImage(event) {
            const reader = new FileReader();
            reader.onload = function () {
                document.getElementById('preview').src = reader.result;
            };
            reader.readAsDataURL(event.target.files[0]);
        }
    </script>

{% endblock %}
