{% extends 'layout/base.html.twig' %}

{% block title %}Sorties{% endblock %}

{% block javascripts %}
    <script src="{{ asset('js/sortieFilter.js') }}" defer></script>
{% endblock %}

{% block main %}
    <h1>Liste des sorties</h1>

    <div class="btn-group">
        <a class="btn" href="{{ path('sortie_create') }}">Proposer une sortie</a>

        {% if is_granted('ROLE_ADMIN') %}
            <form method="post" action="{{ path('sortie_initialize') }}" onsubmit="return confirm('Réinitialiser les sorties de test ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('initialize_sorties') }}">
                <button type="submit" class="btn">
                    Initialiser les sorties
                </button>
            </form>
        {% endif %}
    </div>

    <form method="get" action="{{ path('sortie') }}" id="sortie-filter-form">
        <label for="site">Filtrer par site</label>
        <select name="site" id="site" data-filter-submit>
            <option value="">Tous les sites</option>
            {% for site in sites %}
                <option value="{{ site.id }}" {% if selectedSiteId == site.id %}selected{% endif %}>
                    {{ site.nom }}
                </option>
            {% endfor %}
        </select>
    </form>



    <hr>

    {% if sorties is empty %}
        <br>
        <p>Il n'y actuellement aucune sorties programmées.</p>
    {% else %}
        <section>
            <table>
                <thead>
                <tr>
                    <th>Img</th>
                    <th>Titre</th>
                    <th>Action</th>
                </tr>
                </thead>
                <tbody>
                {% for sortie in sorties %}
                    <tr>
                        <td>
                            {% if sortie.image %}
                                <img src="{{ asset('uploads/' ~ sortie.image) }}" alt="Image-sortie">
                            {% else %}
                                <img src="{{ asset('img/default-image.png') }}" alt="Image par défaut">
                            {% endif %}
                        </td>
                        <td>{{ sortie.nom }}</td>
                        <td>
                            <a href="{{ path('sortie_show', {'id': sortie.id}) }}" class="btn btn-primary">
                                Voir
                            </a>
                        </td>
                    </tr>
                {% endfor %}

                </tbody>
            </table>
        </section>
    {% endif %}
{% endblock %}
