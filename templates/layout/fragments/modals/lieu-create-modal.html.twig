<div
    id="modal-create-lieu"
    onclick="closeModal('modal-create-lieu')"
    class="hidden fixed inset-0 z-50 grid place-items-center bg-black/60 backdrop-blur-sm p-4 cursor-pointer"
>
    <div onclick="event.stopPropagation()" class="conteneur-modal bg-surface space-y-5 overflow-y-auto max-h-[90vh]">
        <button onclick="closeModal('modal-create-lieu')" class="btn-close-modal">✕</button>
        <h2 class="text-xl font-bold uppercase text-[var(--color-primary)]">Créer un lieu</h2>

        {# Champ de recherche Nominatim #}
        <input type="text" id="modal-lieu-recherche" placeholder="Rechercher un lieu (ex: ENI Rennes)..." autocomplete="off" class="w-full">
        <ul id="modal-lieu-suggestions"></ul>

        {# Champs du lieu #}
        <div class="space-y-3">
            <div>
                <label for="modal-lieu-nom">Nom du lieu</label>
                <input type="text" id="modal-lieu-nom" class="w-full">
            </div>
            <div>
                <label for="modal-lieu-rue">Rue</label>
                <input type="text" id="modal-lieu-rue" class="w-full">
            </div>
            <section>
                <div>
                    <label for="modal-lieu-ville-nom">Ville</label>
                    <input type="text" id="modal-lieu-ville-nom" class="w-full">
                </div>
                <div>
                    <label for="modal-lieu-ville-cp">Code postal</label>
                    <input type="text" id="modal-lieu-ville-cp" class="w-full">
                </div>
            </section>
        </div>

        {# Carte Leaflet #}
        <div id="modal-lieu-carte" data-lat="48.1173" data-lng="-1.6778" style="height: 300px; width: 100%;"></div>

        {# Champs cachés lat/lng #}
        <input type="hidden" id="modal-lieu-latitude">
        <input type="hidden" id="modal-lieu-longitude">

        <button type="button" id="modal-lieu-btn-save" class="btn w-full">Enregistrer le lieu</button>
    </div>
</div>
