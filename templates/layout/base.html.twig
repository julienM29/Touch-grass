<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Welcome!{% endblock %}</title>
    <link rel="icon"
          href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% endblock %}

    {% block javascripts %}
        <script src="{{ asset('app.js') }}" defer></script>
        <script src="{{ asset('js/navbar.js') }}" defer></script>
        <script src="{{ asset('js/sortieRegistration.js') }}" defer></script>
        {{ importmap('flashMessageDismiss') }}
        {% block importmap %}{% endblock %}
    {% endblock %}

</head>
<body class="text-gray-800 min-95vh flex flex-col">
<header>
    {% include 'layout/fragments/nav-bar.html.twig' %}
</header>
<main class="bg-background min-h-[90vh] flex justify-center items-center py-24 px-4">
    <div class="w-[85vw] max-w-[72rem] bg-surface rounded-2xl shadow-xl px-4 py-6 md:px-10 md:py-10 flex flex-col text-center">

        {# --- Messages flash --- #}

        {# Erreurs - haut au centre #}
        <div class="fixed top-6 left-1/2 -translate-x-1/2 z-[9999] flex flex-col gap-3 max-w-sm w-full">
            {% for message in app.flashes('error') %}
                <div class="flash-message flex items-center gap-3 px-4 py-3 rounded-xl shadow-lg bg-red-100 text-red-800 border border-red-200">
                    <span class="text-red-500 text-lg">✕</span>
                    <p class="text-sm font-medium">{{ message }}</p>
                </div>
            {% endfor %}
        </div>

        {# Success et warning - bas à droite #}
        <div class="fixed bottom-6 right-6 z-[9999] flex flex-col gap-3 max-w-sm w-full">
            {% for message in app.flashes('success') %}
                <div class="flash-message flex items-center gap-3 px-4 py-3 rounded-xl shadow-lg bg-green-100 text-green-800 border border-green-200">
                    <span class="text-green-500 text-lg">✓</span>
                    <p class="text-sm font-medium">{{ message }}</p>
                </div>
            {% endfor %}
            {% for message in app.flashes('warning') %}
                <div class="flash-message flex items-center gap-3 px-4 py-3 rounded-xl shadow-lg bg-yellow-100 text-yellow-800 border border-yellow-200">
                    <span class="text-yellow-500 text-lg">⚠</span>
                    <p class="text-sm font-medium">{{ message }}</p>
                </div>
            {% endfor %}
        </div>

        {% block main %}{% endblock %}
    </div>
</main>
<footer>
    {% include 'layout/fragments/footer.html.twig' %}
</footer>
</body>
</html>
