<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Welcome!{% endblock %}</title>
    <link rel="icon"
          href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">

    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% endblock %}

    {% block javascripts %}
        <script src="{{ asset('js/navbar.js') }}" defer></script>
        {% block importmap %}{{ importmap('app') }}{% endblock %}
        {{ importmap('flashMessageDismiss') }}
    {% endblock %}

</head>
<body class="text-gray-800 min-95vh flex flex-col">
<header>
    {% include 'layout/fragments/nav-bar.html.twig' %}
</header>
<main class="bg-background min-h-[90vh] flex justify-center items-center py-24 px-4">
    <div class="w-full max-w-2xl bg-surface rounded-2xl shadow-xl px-4 py-6 md:px-10 md:py-10 flex flex-col text-center">
        {# Messages flash #}
        {% for message in app.flashes('success') %}
            <div class="flash-message mb-4 p-3 rounded-lg bg-green-100 text-green-800 absolute">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="flash-message mb-4 p-3 rounded-lg bg-red-100 text-red-800 absolute">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('warning') %}
            <div class="flash-message mb-4 p-3 rounded-lg bg-yellow-100 text-yellow-800 absolute">{{ message }}</div>
        {% endfor %}

        {% block main %}{% endblock %}
    </div>
</main>
<footer>
    {% include 'layout/fragments/footer.html.twig' %}
</footer>
</body>
</html>
