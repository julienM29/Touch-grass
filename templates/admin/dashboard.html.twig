{% extends 'layout/base.html.twig' %}

{% block title %}Dashboard Admin{% endblock %}

{% block main %}


        <h1 class="text-2xl font-bold mb-8 text-[#5C7D5C]">
            Dashboard Administrateur
        </h1>
    {# SECTION ACTIONS #}
    <div class="mb-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <a href="{{ path('admin_participant') }}"
               class="btn">
                Gérer les participants
            </a>

            <a href="{{ path('admin_sorties') }}"
               class="btn">
                Gérer les événements
            </a>

        </div>

    </div>
        {# GRID DES STATS #}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {# Participants #}
        <article class=" ">
            <div class="text-4xl font-black text-[#5C7D5C]">
                {{ nbUtilisateurs }}
            </div>
            <p class=" ">
                Utilisateurs inscrits
            </p>
        </article>

        {# Total événements #}
        <article class=" ">
            <div class="text-4xl font-black text-[#5C7D5C]">
                {{ nbSorties }}
             </div>
            <p class=" ">
                Sorties créés
            </p>
        </article>

        {# À venir #}
        <article class=" ">
            <div class="text-4xl font-black text-[#5C7D5C]">
                {{ sortiesAVenir }}
            </div>
            <p class=" ">
                Sorties à venir
            </p>
        </article>

        {# Passés #}
        <article class=" ">
            <div class="text-4xl font-black text-gray-700">
                {{ sortiesPassees }}
            </div>
            <p class=" ">
                Sorties passés
            </p>
        </article>

        {# Annulés #}
        <article class=" ">
            <div class="text-4xl font-black text-red-500">
                {{ sortiesAnnulees }}
            </div>
            <p class=" ">
                Sorties annulés
            </p>
        </article>

    </div>




{% endblock %}
