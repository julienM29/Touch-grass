{% extends 'layout/base.html.twig' %}

{% block title %}Gestion des Villes{% endblock %}

{% block main %}
    <h1>Liste des villes</h1>
    <a class="btn" href="{{ path('ville_create') }}">Proposer une ville</a>
    <hr>
    {% if villes is empty %}
        <br>
        <p>Il n'y actuellement aucune ville disponible.</p>
    {% else %}

        <section>
            <table>
                <thead>
                <tr>
                    <th>Ville</th>
                    <th>Code Postale</th>
                    <th>Action</th>
                </tr>
                </thead>
                <tbody>
                {% for ville in villes %}
                    <tr>
                        <td><p>{{ ville.nom }}</p></td>
                        <td><p>{{ ville.codePostal }}</p></td>
                        <td><a class="btn" href="{{ path('ville_detail', {'id': ville.id}) }}">Detail</a></td>
                    </tr>
                {% endfor %}

                </tbody>
            </table>
        </section>
    {% endif %}
{% endblock %}
